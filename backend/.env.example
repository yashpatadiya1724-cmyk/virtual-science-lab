# Virtual Science Lab – Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5500

# MongoDB
MONGODB_URI=mongodb://localhost:27017/virtual-science-lab
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/virtual-science-lab

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES=7d

# Optional: AWS S3 for asset uploads
# AWS_ACCESS_KEY=
# AWS_SECRET_KEY=
# AWS_BUCKET=virtual-science-lab-assets
